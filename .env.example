# =============================================================================
# fraud_detect_api — LLM classifier (port 8081)
# =============================================================================
# Required for the /api/scan endpoint to return regulatory / scam classification.
# Without these, scraping still works but `verdict`, `scam`, `regulatory`,
# `localisation`, and `evidence_summary` will be null.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=ilmu-mini-v3
# Optional: set to "low" or "high" to enable extra_body reasoning effort.
# Leave blank for models that don't support it.
LLM_REASONING_EFFORT=

# =============================================================================
# frontend — Vite env (optional; localhost defaults are baked in)
# =============================================================================
# VITE_MULE_API_URL=http://localhost:8000
# VITE_LAYER3_API_URL=http://localhost:8083
# VITE_SCRAPE_API_URL=http://localhost:8081
